{
  "name": "diffbudget",
  "version": "0.1.0",
  "description": "Local patch risk budgets before a commit escapes.",
  "type": "module",
  "bin": {
    "diffbudget": "./dist/cli.js",
    "dbudget": "./dist/cli.js"
  },
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE",
    "SECURITY.md"
  ],
  "scripts": {
    "build": "tsc",
    "check": "tsc --noEmit",
    "test": "npm run build && node --test dist/*.test.js",
    "smoke": "bash scripts/smoke.sh",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm run check && npm test && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "git",
    "diff",
    "risk",
    "budget",
    "cli",
    "local-first"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "typescript": "^5.7.2"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/diffbudget.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/diffbudget/issues"
  },
  "homepage": "https://github.com/rogerchappel/diffbudget#readme"
}
